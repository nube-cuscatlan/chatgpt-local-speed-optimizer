{
  "manifest_version": 3,
  "name": "Local Speed Optimizer for ChatGPT",
  "version": "1.1.0",
"description": "Speeds up long ChatGPT chats by hiding older messages locally. No accounts, tracking, or external APIs.",  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Local Speed Optimizer for ChatGPT",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/optimizer.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "homepage_url": "https://chatgpt.com"
}
